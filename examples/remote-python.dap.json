{
  "name": "Remote Python (debugpy over TCP)",
  "adapterId": "debugpy",
  "request": "attach",
  "host": "127.0.0.1",
  "port": 5678,
  "attach": {
    "type": "python",
    "request": "attach",
    "connect": { "host": "127.0.0.1", "port": 5678 },
    "justMyCode": false
  },
  "pathMappings": [
    { "localRoot": "${workspaceFolder}", "remoteRoot": "/app" }
  ],
  "exceptionBreakpoints": ["uncaught"],
  "_note": "Start debugpy on the remote: python3 -m debugpy --listen 0.0.0.0:5678 --wait-for-client app.py"
}
